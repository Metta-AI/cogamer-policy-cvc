<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>CvC run {{ run_id }}</title>
<style>
:root {
  --bg: #0f172a;
  --panel: #1e293b;
  --panel2: #273449;
  --fg: #e2e8f0;
  --muted: #94a3b8;
  --accent: #38bdf8;
  --ok: #10b981;
  --bad: #ef4444;
  --warn: #f59e0b;
  --border: #334155;
}
* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; background: var(--bg); color: var(--fg);
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 13px; }
header { padding: 12px 16px; border-bottom: 1px solid var(--border);
  display: flex; flex-wrap: wrap; gap: 14px; align-items: baseline;
  background: var(--panel); }
header h1 { font-size: 15px; margin: 0; color: var(--accent); }
header .meta { color: var(--muted); }
.badge { display: inline-block; padding: 2px 8px; border-radius: 4px;
  font-weight: 600; }
.badge.passed { background: var(--ok); color: #04231a; }
.badge.failed { background: var(--bad); color: #2a0606; }
.badge.crashed { background: var(--bad); color: #2a0606; }
.badge.unknown { background: var(--border); color: var(--fg); }
.banner-fail { background: #450a0a; border: 1px solid var(--bad);
  padding: 10px 16px; margin: 0; color: #fecaca; }
.banner-fail button { background: transparent; color: var(--bad);
  border: 1px solid var(--bad); padding: 2px 8px; margin-right: 8px;
  cursor: pointer; font-family: inherit; }
main { display: grid; grid-template-columns: 3fr 2fr; gap: 10px;
  padding: 10px; }
section { background: var(--panel); border: 1px solid var(--border);
  border-radius: 6px; padding: 10px; }
section h2 { margin: 0 0 8px; font-size: 13px; color: var(--muted);
  text-transform: uppercase; letter-spacing: 0.05em; }
.log-card .log-filters { display: flex; flex-direction: column; gap: 6px;
  padding: 6px 0; border-bottom: 1px solid var(--border); margin-bottom: 6px; }
.log-card .log-filters .row { display: flex; flex-wrap: wrap; gap: 6px;
  align-items: center; }
.log-card .log-filters .group-label { color: var(--muted); text-transform: uppercase;
  letter-spacing: 0.05em; font-size: 11px; margin-right: 4px; }
.log-card label.agent-cb { display: inline-flex; align-items: center; gap: 3px;
  padding: 1px 6px; border: 1px solid var(--border); border-radius: 3px;
  background: var(--panel2); cursor: pointer; font-size: 12px; }
.chips { display: flex; flex-wrap: wrap; gap: 6px; }
.chip { padding: 2px 8px; border-radius: 10px; border: 1px solid var(--border);
  background: var(--panel2); cursor: pointer; user-select: none;
  display: inline-flex; align-items: center; gap: 6px; }
.chip .dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
.chip.off { opacity: 0.4; }
.replay-card iframe { width: 100%; min-height: 480px; border: 0;
  background: var(--panel2); border-radius: 4px; }
.replay-fallback { padding: 1em; color: var(--muted); font-size: 0.9em; }
.replay-cmd-line { font-size: 0.85em; opacity: 0.7; margin-top: 0.5em;
  display: flex; gap: 0.5em; align-items: center; }
.replay-cmd-line code { flex: 1; word-break: break-all; }
.copy-badge { font-size: 0.75em; padding: 1px 6px;
  border: 1px solid var(--border); border-radius: 3px; cursor: pointer;
  background: transparent; color: var(--fg); font-family: inherit; }
.tabs { display: flex; gap: 4px; margin-bottom: 6px; }
.tabs button { background: var(--panel2); color: var(--fg); border: 0;
  padding: 4px 10px; border-radius: 4px 4px 0 0; cursor: pointer;
  font-family: inherit; }
.tabs button.active { background: var(--accent); color: #04231a; }
input[type="search"] { width: 100%; padding: 4px 6px; background: var(--panel2);
  color: var(--fg); border: 1px solid var(--border); border-radius: 4px;
  font-family: inherit; }
#log { max-height: 70vh; overflow-y: auto; margin-top: 6px; }
#log .line { padding: 2px 4px; border-left: 3px solid transparent;
  white-space: pre-wrap; word-break: break-word; }
#log .line.current { border-left-color: var(--accent); background: var(--panel2); }
#log .line.hidden { display: none; }
#log .line .meta { color: var(--muted); }
#log .stream { display: inline-block; padding: 1px 4px; border-radius: 3px;
  color: #fff; font-size: 10px; font-weight: 600; margin-right: 4px;
  vertical-align: middle; }
#log .stream-py { background: #3b82f6; }
#log .stream-llm { background: #a855f7; }
#log .agent-tag { display: inline-block; font-family: ui-monospace, Menlo, monospace;
  font-size: 10px; font-weight: 600; margin-right: 4px; vertical-align: middle; }
#log .type { color: var(--muted); margin-right: 4px; }
#log hr.step-sep { border: 0; border-top: 1px solid var(--border);
  margin: 4px 0; }
#log .step-marker { color: var(--muted); font-size: 10px;
  text-transform: uppercase; letter-spacing: 0.05em; padding: 0 4px; }
#log .step-range { color: var(--muted); font-size: 10px; opacity: 0.5;
  letter-spacing: 0.05em; padding: 0 4px; cursor: pointer;
  font-style: italic; }
#log .step-range.current { opacity: 1; color: var(--accent); }
footer { position: sticky; bottom: 0; background: var(--panel);
  border-top: 1px solid var(--border); padding: 8px 16px;
  display: flex; gap: 10px; align-items: center; }
footer input[type="range"] { flex: 1; }
footer button, footer select { background: var(--panel2); color: var(--fg);
  border: 1px solid var(--border); border-radius: 4px; padding: 2px 8px;
  cursor: pointer; font-family: inherit; }
</style>
</head>
<body>
<header>
  <h1>{{ run_id }}</h1>
  <span class="badge {{ status }}">{{ status }}</span>
  <span class="meta">scenario={{ scenario }}</span>
  <span class="meta">duration={{ '%.2f'|format(duration_s) }}s</span>
  <span class="meta">cogs={{ cogs }}</span>
  <span class="meta">seed={{ seed }}</span>
  <span class="meta">steps={{ steps }}</span>
  <span class="meta">mission={{ mission }}</span>
</header>

{% if status == "failed" or status == "crashed" %}
<div class="banner-fail">
  <strong>Run {{ status }}.</strong>
  {% for a in assertions %}
    {% if not a.passed %}
      <button type="button" class="jump-fail"
        data-step="{{ a.failed_at_step if a.failed_at_step is not none else 0 }}">
        {{ a.name }}
      </button>
      <span>{{ a.message }}{% if a.failed_at_step is not none %} (step {{ a.failed_at_step }}){% endif %}</span>
      &nbsp;&nbsp;
    {% endif %}
  {% endfor %}
</div>
{% endif %}

<main>
  <section class="replay-card">
    <h2>Replay</h2>
    {% if has_replay %}
    <iframe id="mettascope" allowfullscreen></iframe>
    <noscript>JavaScript required for embedded replay.</noscript>
    <div class="replay-cmd-line">
      <code>softmax cogames replay {{ replay_abs_path }}</code>
      <button class="copy-badge" type="button"
        data-copy="softmax cogames replay {{ replay_abs_path }}">copy</button>
    </div>
    {% else %}
    <div class="meta">(no replay.json.z found)</div>
    {% endif %}
  </section>

  <section class="log-card">
    <h2>Log</h2>
    <div class="log-filters">
      <div class="row">
        <input type="search" id="search" placeholder="filter text (across payloads + rationale)">
      </div>
      <div class="row">
        <span class="group-label">Types</span>
        <div class="chips" id="type-chips">
          {% for t, n, color in type_counts %}
          <span class="chip" data-type="{{ t }}">
            <span class="dot" style="background: {{ color }}"></span>
            {{ t }} <span class="meta">({{ n }})</span>
          </span>
          {% endfor %}
        </div>
      </div>
      <div class="row">
        <span class="group-label">Agents</span>
        {% for a in agents %}
        <label class="agent-cb">
          <input type="checkbox" checked class="agent-toggle" data-agent="{{ a }}">
          <span style="color: {{ agent_color(a) }}">a{{ a }}</span>
        </label>
        {% endfor %}
      </div>
    </div>
    <div class="tabs" id="tabs">
      <button type="button" class="tab active" data-tab="all">All</button>
      <button type="button" class="tab" data-tab="py">Py</button>
      <button type="button" class="tab" data-tab="llm">LLM</button>
      <button type="button" class="tab" data-tab="team">Team</button>
    </div>
    <div id="log">
      {% for g in log_groups %}
      {% if not loop.first %}<hr class="step-sep">{% endif %}
      {% if g.type == "range" %}
      <div class="step-range" data-start="{{ g.start }}" data-end="{{ g.end }}">[{{ g.start }}-{{ g.end }}]</div>
      {% else %}
      <div class="step-marker" data-step="{{ g.step }}">step {{ g.step }}</div>
      {% for ln in g.lines %}
      <div class="line" data-idx="{{ ln.idx }}" data-step="{{ ln.step }}"
           data-agent="{{ ln.agent if ln.agent is not none else '' }}"
           data-stream="{{ ln.stream }}"
           data-type="{{ ln.type }}"><span class="stream stream-{{ ln.stream }}">{{ ln.stream }}</span>{% if ln.agent is not none %}<span class="agent-tag" style="color: {{ agent_color(ln.agent) }}">a{{ ln.agent }}</span>{% endif %}<span class="type">{{ ln.type }}</span><span class="payload">{{ ln.text }}</span></div>
      {% endfor %}
      {% endif %}
      {% endfor %}
    </div>
  </section>
</main>

<footer>
  <button type="button" id="play">Play</button>
  <input type="range" id="scrubber" min="0" max="{{ max_step }}" value="0">
  <span id="step-label">step 0 / {{ max_step }}</span>
  <select id="speed">
    <option value="1">1x</option>
    <option value="4">4x</option>
    <option value="16">16x</option>
  </select>
</footer>

<script type="application/json" id="events">{{ events_json|safe }}</script>
<script>
(function () {
  var events = JSON.parse(document.getElementById('events').textContent);
  var maxStep = {{ max_step }};
  var scrub = document.getElementById('scrubber');
  var stepLabel = document.getElementById('step-label');
  var playBtn = document.getElementById('play');
  var speedSel = document.getElementById('speed');
  var search = document.getElementById('search');
  var log = document.getElementById('log');
  var typeChips = document.getElementById('type-chips');
  var tabs = document.getElementById('tabs');

  var hiddenTypes = {};
  var hiddenAgents = {};
  var currentTab = 'all';
  var playing = false;
  var timer = null;

  function setStep(step) {
    step = Math.max(0, Math.min(maxStep, Math.floor(step)));
    scrub.value = step;
    stepLabel.textContent = 'step ' + step + ' / ' + maxStep;
    // Highlight current-step log lines.
    log.querySelectorAll('.line').forEach(function (el) {
      if (parseInt(el.dataset.step, 10) === step) el.classList.add('current');
      else el.classList.remove('current');
    });
    // Highlight the range marker if step falls inside it.
    log.querySelectorAll('.step-range').forEach(function (el) {
      var a = parseInt(el.dataset.start, 10);
      var b = parseInt(el.dataset.end, 10);
      if (step >= a && step <= b) el.classList.add('current');
      else el.classList.remove('current');
    });
    // Scroll first current line into view (or the current range marker
    // if we're inside an empty gap).
    var firstCurrent = log.querySelector('.line.current')
      || log.querySelector('.step-range.current');
    if (firstCurrent) firstCurrent.scrollIntoView({block: 'nearest'});
  }

  scrub.addEventListener('input', function () { setStep(+scrub.value); });

  playBtn.addEventListener('click', function () {
    playing = !playing;
    playBtn.textContent = playing ? 'Pause' : 'Play';
    if (timer) { clearInterval(timer); timer = null; }
    if (playing) {
      var speed = +speedSel.value;
      timer = setInterval(function () {
        var s = +scrub.value + speed;
        if (s >= maxStep) { s = maxStep; playing = false;
          playBtn.textContent = 'Play'; clearInterval(timer); timer = null; }
        setStep(s);
      }, 50);
    }
  });

  function applyFilters() {
    var q = (search.value || '').toLowerCase();
    log.querySelectorAll('.line').forEach(function (el) {
      var type = el.dataset.type;
      var agent = el.dataset.agent;
      var stream = el.dataset.stream;
      var text = el.textContent.toLowerCase();
      var hide = false;
      if (hiddenTypes[type]) hide = true;
      if (agent !== '' && hiddenAgents[agent]) hide = true;
      if (currentTab === 'py' && stream !== 'py') hide = true;
      if (currentTab === 'llm' && stream !== 'llm') hide = true;
      if (currentTab === 'team' && agent !== '') hide = true;
      if (q && text.indexOf(q) === -1) hide = true;
      el.classList.toggle('hidden', hide);
    });
  }

  typeChips.addEventListener('click', function (e) {
    var chip = e.target.closest('.chip');
    if (!chip) return;
    var t = chip.dataset.type;
    hiddenTypes[t] = !hiddenTypes[t];
    chip.classList.toggle('off', !!hiddenTypes[t]);
    applyFilters();
  });

  document.querySelectorAll('.agent-toggle').forEach(function (cb) {
    cb.addEventListener('change', function () {
      hiddenAgents[cb.dataset.agent] = !cb.checked;
      applyFilters();
    });
  });

  tabs.addEventListener('click', function (e) {
    var b = e.target.closest('.tab');
    if (!b) return;
    currentTab = b.dataset.tab;
    tabs.querySelectorAll('.tab').forEach(function (x) {
      x.classList.toggle('active', x === b);
    });
    applyFilters();
  });

  search.addEventListener('input', applyFilters);

  document.querySelectorAll('.jump-fail').forEach(function (b) {
    b.addEventListener('click', function () { setStep(+b.dataset.step); });
  });

  // Clicking a collapsed empty-range marker jumps to its start step.
  log.addEventListener('click', function (e) {
    var r = e.target.closest('.step-range');
    if (!r) return;
    setStep(+r.dataset.start);
  });

  // Delegated copy handler for any element with data-copy.
  document.addEventListener('click', function (e) {
    var el = e.target.closest('[data-copy]');
    if (!el) return;
    var text = el.getAttribute('data-copy') || '';
    if (navigator.clipboard) navigator.clipboard.writeText(text);
  });

  (function setupReplay() {
    var iframe = document.getElementById('mettascope');
    if (!iframe) return;
    var proto = window.location.protocol;
    if (proto === 'http:' || proto === 'https:') {
      var replayUrl = new URL('./replay.json.z', window.location.href).href;
      // Probe the locally-served mettascope dist; fall back to the
      // github-pages URL if the server didn't mount it (mixed content
      // may block it in browsers in that case).
      var localBase = new URL('./mettascope/mettascope.html', window.location.href).href;
      var remoteBase = 'https://metta-ai.github.io/metta/mettascope/mettascope.html';
      fetch('./mettascope/mettascope.html', {method: 'HEAD'}).then(function (r) {
        var base = r.ok ? localBase : remoteBase;
        iframe.src = base + '?replay=' + encodeURIComponent(replayUrl);
      }).catch(function () {
        iframe.src = remoteBase + '?replay=' + encodeURIComponent(replayUrl);
      });
    } else {
      iframe.outerHTML = '<div class="replay-fallback">Open via <code>cgp view</code> for embedded replay (needs HTTP server).</div>';
    }
  })();

  setStep(0);
})();
</script>
</body>
</html>
