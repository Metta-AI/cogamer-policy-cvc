<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>CvC run {{ run_id }}</title>
<style>
:root {
  --bg: #0f172a;
  --panel: #1e293b;
  --panel2: #273449;
  --fg: #e2e8f0;
  --muted: #94a3b8;
  --accent: #38bdf8;
  --ok: #10b981;
  --bad: #ef4444;
  --warn: #f59e0b;
  --border: #334155;
}
* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; background: var(--bg); color: var(--fg);
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 13px; }
html, body { height: 100%; }
body { display: flex; flex-direction: column; }
header { padding: 12px 16px; border-bottom: 1px solid var(--border);
  display: flex; flex-wrap: wrap; gap: 14px; align-items: baseline;
  background: var(--panel); }
header h1 { font-size: 15px; margin: 0; color: var(--accent); }
header .meta { color: var(--muted); }
.badge { display: inline-block; padding: 2px 8px; border-radius: 4px;
  font-weight: 600; }
.badge.passed { background: var(--ok); color: #04231a; }
.badge.failed { background: var(--bad); color: #2a0606; }
.badge.crashed { background: var(--bad); color: #2a0606; }
.badge.unknown { background: var(--border); color: var(--fg); }
.banner-fail { background: #450a0a; border: 1px solid var(--bad);
  padding: 10px 16px; margin: 0; color: #fecaca; }
.banner-fail button { background: transparent; color: var(--bad);
  border: 1px solid var(--bad); padding: 2px 8px; margin-right: 8px;
  cursor: pointer; font-family: inherit; }
main { display: grid; grid-template-columns: var(--main-cols, 3fr 6px 2fr); gap: 0;
  padding: 10px; flex: 1 1 auto; min-height: 0; }
#col-resize { width: 6px; cursor: col-resize; background: transparent;
  border-left: 1px solid transparent; border-right: 1px solid transparent;
  user-select: none; touch-action: none; }
#col-resize:hover, #col-resize.dragging {
  background: var(--accent); opacity: 0.4; }
main > section { margin: 0 4px; }
section { background: var(--panel); border: 1px solid var(--border);
  border-radius: 6px; padding: 10px;
  display: flex; flex-direction: column; min-height: 0; }
section h2 { margin: 0 0 8px; font-size: 13px; color: var(--muted);
  text-transform: uppercase; letter-spacing: 0.05em; }
.log-card h2 { display: flex; align-items: center; gap: 8px; }
.log-card h2 .filters-toggle { margin-left: auto; font-size: 0.75em;
  padding: 1px 8px; border: 1px solid var(--border); border-radius: 3px;
  background: var(--panel2); color: var(--fg); cursor: pointer;
  font-family: inherit; text-transform: none; letter-spacing: 0; }
.log-card h2 .filters-toggle.collapsed { opacity: 0.6; }
.log-card .log-filters { display: flex; flex-direction: column; gap: 6px;
  padding: 6px 0; border-bottom: 1px solid var(--border); margin-bottom: 6px; }
.log-card .log-filters.collapsed { display: none; }
.log-card .log-filters .row { display: flex; flex-wrap: wrap; gap: 6px;
  align-items: center; }
.log-card .log-filters .group-label { color: var(--muted); text-transform: uppercase;
  letter-spacing: 0.05em; font-size: 11px; margin-right: 4px; }
.log-card label.agent-cb { display: inline-flex; align-items: center; gap: 3px;
  padding: 1px 6px; border: 1px solid var(--border); border-radius: 3px;
  background: var(--panel2); cursor: pointer; font-size: 12px; }
.chips { display: flex; flex-wrap: wrap; gap: 6px; }
.chip { padding: 2px 8px; border-radius: 10px; border: 1px solid var(--border);
  background: var(--panel2); cursor: pointer; user-select: none;
  display: inline-flex; align-items: center; gap: 6px; }
.chip .dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
.chip.off { opacity: 0.4; }
.replay-card iframe { width: 100%; flex: 1 1 auto; min-height: 0; border: 0;
  background: var(--panel2); border-radius: 4px; }
.replay-fallback { padding: 1em; color: var(--muted); font-size: 0.9em; }
.copy-btn { font-size: 0.75em; padding: 1px 6px;
  border: 1px solid var(--border); border-radius: 3px; cursor: pointer;
  background: transparent; color: var(--fg); font-family: inherit; }
.header-copy { margin-left: auto; }
.tabs { display: flex; gap: 4px; margin-bottom: 6px; }
.tabs button { background: var(--panel2); color: var(--fg); border: 0;
  padding: 4px 10px; border-radius: 4px 4px 0 0; cursor: pointer;
  font-family: inherit; }
.tabs button.active { background: var(--accent); color: #04231a; }
input[type="search"] { width: 100%; padding: 4px 6px; background: var(--panel2);
  color: var(--fg); border: 1px solid var(--border); border-radius: 4px;
  font-family: inherit; }
#log { flex: 1 1 auto; min-height: 0; overflow-y: auto; margin-top: 6px; }
#log .line { padding: 2px 4px; border-left: 3px solid transparent;
  white-space: pre-wrap; word-break: break-word; }
#log .line.current { border-left-color: var(--accent); background: var(--panel2); }
#log .line.hidden { display: none; }
#log .line.merged-hidden { display: none; }
#log .step-marker.merged-hidden { display: none; }
#log .step-marker.hidden { display: none; }
#log hr.step-sep.hr-hidden { display: none; }
/* Left column: step number (vertical) on the first line of a step
   block, merge-range badge on merged runs, or empty on follow-up
   lines. Column is compact so the content gets more horizontal room. */
#log .line { padding-left: 28px; position: relative; }
#log .line.step-start[data-step-label]::before {
  content: attr(data-step-label);
  position: absolute; left: 0; top: 0; width: 22px;
  color: var(--muted); opacity: 0.6;
  font-size: 10px; letter-spacing: 0.05em;
  writing-mode: vertical-rl; transform: rotate(180deg);
  text-align: left; padding: 1px 0; }
#log .step-range-badge { position: absolute; left: 0; top: 0;
  width: 22px; color: var(--muted); opacity: 0.7;
  font-size: 9px; font-style: italic; text-align: left;
  writing-mode: vertical-rl; transform: rotate(180deg);
  padding: 1px 0; margin-right: 0; }
#log .line.in-merged-run::before { content: none; }
#log .step-marker { padding-left: 28px; }
/* Follow-up events within the same step that share the agent — the
   agent/role glyphs are suppressed, content sits in the content column. */
#log .line.agent-dupe .type::before { content: '\21B3\2002'; /* ↳ */
  opacity: 0.35; margin-right: 2px; }
#log .line { cursor: pointer; }
#log .step-marker { cursor: pointer; }
#log .line .meta { color: var(--muted); }
/* Stream indicated by whole-line color: py = white, llm = green. */
#log .line[data-stream="py"] { color: #f1f5f9; }
#log .line[data-stream="llm"] { color: #10b981; }
#log .agent-tag { display: inline-block; font-family: ui-monospace, Menlo, monospace;
  font-size: 10px; font-weight: 600; margin-right: 4px; vertical-align: middle; }
#log .type { color: var(--muted); margin-right: 4px; }
#log .role-icon { margin-right: 4px; font-size: 0.9em; }
.inventory-panel { display: flex; flex-direction: column; gap: 2px;
  padding: 6px 4px; margin-bottom: 6px;
  border-bottom: 1px solid var(--border); font-size: 12px; }
.inventory-panel .inv-row { display: flex; align-items: center; gap: 8px;
  padding: 2px 4px; border-radius: 3px;
  white-space: nowrap; overflow: hidden; }
.inventory-panel .inv-agent { font-weight: 700; }
.inventory-panel .inv-role { display: inline-flex; gap: 2px;
  align-items: center; }
.inventory-panel .inv-hp { display: inline-flex; gap: 2px;
  align-items: center; color: #f87171; }
.inventory-panel .inv-cargo { display: inline-flex; gap: 4px;
  align-items: center; }
.inventory-panel .inv-row.stale { opacity: 0.4; }
.inventory-panel .inv-row.active { outline: 1px solid var(--accent);
  border-radius: 4px; }
.inventory-panel .agent-eye { background: transparent; border: 0;
  cursor: pointer; color: var(--fg); padding: 0 2px; font-size: 13px;
  user-select: none; }
.inventory-panel .agent-eye.hidden-eye { opacity: 0.25;
  text-decoration: line-through; }
.inventory-panel .inv-badge { display: inline-flex; align-items: center;
  gap: 2px; padding: 1px 4px; border-radius: 3px;
  background: var(--panel2); cursor: help; font-size: 12px;
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
.inventory-panel .inv-badge .inv-icon { font-weight: 700; opacity: 0.7; }
.inventory-panel .inv-badge .inv-count { font-weight: 600; }
.inventory-panel .inv-bar { display: inline-flex; gap: 1px;
  align-items: center; padding: 2px 4px; border-radius: 3px;
  background: var(--panel2); cursor: help; }
.inventory-panel .inv-bar .seg { width: 5px; height: 10px;
  background: #334155; border-radius: 1px; }
.inventory-panel .inv-bar.hp .seg.filled { background: #10b981; }
.inventory-panel .inv-bar.energy .seg.filled { background: #facc15; }
#log hr.step-sep { border: 0; border-top: 1px solid var(--border);
  margin: 4px 0; height: 0; }
#log .step-marker { color: var(--muted); font-size: 10px;
  text-transform: uppercase; letter-spacing: 0.05em; padding: 0 4px; }
#log .step-range { color: var(--muted); font-size: 10px; opacity: 0.5;
  letter-spacing: 0.05em; padding: 0 4px; cursor: pointer;
  font-style: italic; }
#log .step-range.current { opacity: 1; color: var(--accent); }
footer { position: sticky; bottom: 0; background: var(--panel);
  border-top: 1px solid var(--border); padding: 8px 16px;
  display: flex; gap: 10px; align-items: center; }
footer input[type="range"] { flex: 1; }
footer button, footer select { background: var(--panel2); color: var(--fg);
  border: 1px solid var(--border); border-radius: 4px; padding: 2px 8px;
  cursor: pointer; font-family: inherit; }
</style>
</head>
<body>
<header>
  <h1>{{ run_id }}</h1>
  <span class="badge {{ status }}">{{ status }}</span>
  <span class="meta">scenario={{ scenario }}</span>
  <span class="meta">duration={{ '%.2f'|format(duration_s) }}s</span>
  <span class="meta">cogs={{ cogs }}</span>
  <span class="meta">seed={{ seed }}</span>
  <span class="meta">steps={{ steps }}</span>
  <span class="meta">mission={{ mission }}</span>
  {% if has_replay %}
  <button type="button" class="copy-btn header-copy"
    data-copy="softmax cogames replay {{ replay_abs_path }}"
    title="softmax cogames replay {{ replay_abs_path }}">copy replay cmd</button>
  {% endif %}
</header>

{% if status == "failed" or status == "crashed" %}
<div class="banner-fail">
  <strong>Run {{ status }}.</strong>
  {% for a in assertions %}
    {% if not a.passed %}
      <button type="button" class="jump-fail"
        data-step="{{ a.failed_at_step if a.failed_at_step is not none else 0 }}">
        {{ a.name }}
      </button>
      <span>{{ a.message }}{% if a.failed_at_step is not none %} (step {{ a.failed_at_step }}){% endif %}</span>
      &nbsp;&nbsp;
    {% endif %}
  {% endfor %}
</div>
{% endif %}

<main id="main-grid">
  <section class="replay-card">
    <h2>Replay</h2>
    {% if has_replay %}
    <iframe id="mettascope" allowfullscreen></iframe>
    <noscript>JavaScript required for embedded replay.</noscript>
    {% else %}
    <div class="meta">(no replay.json.z found)</div>
    {% endif %}
  </section>

  <div id="col-resize" role="separator" aria-orientation="vertical" tabindex="0"></div>

  <section class="log-card">
    <h2>Log
      <button type="button" id="filters-toggle" class="filters-toggle collapsed"
        aria-expanded="false" title="Show/hide filters">filters</button>
    </h2>
    <div class="log-filters collapsed" id="log-filters">
      <div class="row">
        <input type="search" id="search" placeholder="filter text (across payloads + rationale)">
      </div>
      <div class="row">
        <span class="group-label">Types</span>
        <div class="chips" id="type-chips">
          {% for t, n, color in type_counts %}
          <span class="chip{% if t == 'inventory' %} off{% endif %}" data-type="{{ t }}">
            <span class="dot" style="background: {{ color }}"></span>
            {{ t }} <span class="meta">({{ n }})</span>
          </span>
          {% endfor %}
        </div>
      </div>
      <div class="row">
        <span class="group-label">Agents</span>
        {% for a in agents %}
        <label class="agent-cb">
          <input type="checkbox" checked class="agent-toggle" data-agent="{{ a }}">
          <span style="color: {{ agent_color(a) }}">a{{ a }}</span>
        </label>
        {% endfor %}
      </div>
      <div class="row">
        <span class="group-label">Stream</span>
        <div class="tabs" id="tabs">
          <button type="button" class="tab active" data-tab="all">All</button>
          <button type="button" class="tab" data-tab="py">Py</button>
          <button type="button" class="tab" data-tab="llm">LLM</button>
          <button type="button" class="tab" data-tab="team">Team</button>
        </div>
      </div>
    </div>
    <div id="inventory-panel" class="inventory-panel">
      {% for a in agents %}
      <div class="inv-row" data-agent="{{ a }}">
        <button type="button" class="agent-eye" data-agent="{{ a }}"
          title="click: toggle in log | dblclick: solo / show-all">&#x1F441;</button>
        <span class="inv-agent" style="color: {{ agent_color(a) }}">a{{ a }}</span>
        <span class="inv-role"></span>
        <span class="inv-hp"></span>
        <span class="inv-cargo"></span>
      </div>
      {% endfor %}
    </div>
    <div id="log">
      {% for g in log_groups %}
      {% if not loop.first %}<hr class="step-sep">{% endif %}
      {% if g.type == "range" %}
      <div class="step-range" data-start="{{ g.start }}" data-end="{{ g.end }}">[{{ g.start }}-{{ g.end }}]</div>
      {% else %}
      {# Compact step marker in the left column — vertical layout on the
         first line of each step rather than a standalone horizontal row. #}
      {% if g.lines %}
      {% for ln in g.lines %}
      <div class="line{% if loop.first %} step-start{% endif %}{% if ln.hide_agent %} agent-dupe{% endif %}"
           data-idx="{{ ln.idx }}" data-step="{{ ln.step }}"
           {% if loop.first %}data-step-label="{{ g.step }}"{% endif %}
           data-agent="{{ ln.agent if ln.agent is not none else '' }}"
           data-stream="{{ ln.stream }}"
           data-type="{{ ln.type }}"
           data-payload="{{ ln.text }}">{% if ln.agent is not none and not ln.hide_agent %}<span class="agent-tag" style="color: {{ agent_color(ln.agent) }}">a{{ ln.agent }}</span>{% endif %}{% if ln.role and role_glyph(ln.role) and not ln.hide_agent %}<span class="role-icon" title="{{ ln.role }}">{{ role_glyph(ln.role) }}</span>{% endif %}<span class="type">{{ ln.type }}</span><span class="payload">{{ ln.text }}</span></div>
      {% endfor %}
      {% else %}
      <div class="step-marker" data-step="{{ g.step }}" data-original="step {{ g.step }}">step {{ g.step }}</div>
      {% endif %}
      {% endif %}
      {% endfor %}
    </div>
  </section>
</main>

<script type="application/json" id="events">{{ events_json|safe }}</script>
<script type="application/json" id="inventory-by-agent-step">{{ inventory_by_agent_step_json|safe }}</script>
<script>
(function () {
  var events = JSON.parse(document.getElementById('events').textContent);
  var inventoryByAgentStep = JSON.parse(
    document.getElementById('inventory-by-agent-step').textContent);
  var maxStep = {{ max_step }};

  // Compact per-resource glyphs. Hover shows the full name.
  var INV_ICONS = {
    carbon: 'c',
    oxygen: 'o',
    germanium: 'g',
    silicon: 's',
    heart: '<3',
    miner: "\u26cf",
    aligner: "\ud83d\udd17",
    scrambler: "\ud83c\udf00",
    scout: "\ud83d\udd2d"
  };
  var INV_CARGO_KEYS = ['carbon', 'oxygen', 'germanium', 'silicon', 'heart'];
  var INV_MAX = {hp: 100, energy: 100};

  function _findLatestHeartbeat(agent, step) {
    var entries = inventoryByAgentStep[String(agent)];
    if (!entries || entries.length === 0) return null;
    // Binary search for the largest entries[i].step <= step. If none
    // qualify (scrubber before the first recorded snapshot), fall back
    // to the earliest entry so the panel shows *something* on load.
    var lo = 0, hi = entries.length - 1, best = -1;
    while (lo <= hi) {
      var mid = (lo + hi) >> 1;
      if (entries[mid].step <= step) { best = mid; lo = mid + 1; }
      else { hi = mid - 1; }
    }
    if (best < 0) return entries[0];
    return entries[best];
  }

  function _invBadge(key, count, label) {
    var icon = INV_ICONS[key] || key;
    var text = (label || key) + ': ' + count;
    return '<span class="inv-badge" title="' + text + '">' +
           '<span class="inv-icon">' + icon + '</span>' +
           '<span class="inv-count">' + count + '</span></span>';
  }
  function _invBar(key, count) {
    var max = INV_MAX[key] || 100;
    var segs = 10;
    var filled = Math.max(0, Math.min(segs, Math.round(count / max * segs)));
    var html = '';
    for (var i = 0; i < segs; i++) {
      html += '<span class="seg' + (i < filled ? ' filled' : '') + '"></span>';
    }
    return '<span class="inv-bar ' + key + '" title="' + key + ': ' + count +
           '/' + max + '">' + html + '</span>';
  }
  function updateInventoryPanel(step) {
    var panel = document.getElementById('inventory-panel');
    if (!panel) return;
    var rows = panel.querySelectorAll('.inv-row');
    rows.forEach(function (row) {
      var agent = parseInt(row.dataset.agent, 10);
      var hit = _findLatestHeartbeat(agent, step);
      var roleEl = row.querySelector('.inv-role');
      var hpEl = row.querySelector('.inv-hp');
      var cargoEl = row.querySelector('.inv-cargo');
      if (!hit) {
        row.classList.add('stale');
        if (roleEl) roleEl.innerHTML = '';
        if (hpEl) hpEl.innerHTML = '';
        if (cargoEl) cargoEl.innerHTML = '';
        return;
      }
      row.classList.remove('stale');
      var p = hit.payload || {};
      if (roleEl) {
        roleEl.innerHTML = p.role
          ? '<span class="inv-badge" title="role: ' + p.role + '">' +
            (INV_ICONS[p.role] || p.role) + '</span>'
          : '';
      }
      if (hpEl) {
        var inv = p.inventory || {};
        var pieces = [];
        if (p.hp !== undefined) pieces.push(_invBar('hp', p.hp));
        if (inv.energy !== undefined) pieces.push(_invBar('energy', inv.energy));
        hpEl.innerHTML = pieces.join('');
      }
      var inv = p.inventory || {};
      var parts = [];
      INV_CARGO_KEYS.forEach(function (k) {
        if (inv[k] !== undefined) parts.push(_invBadge(k, inv[k], k));
      });
      if (cargoEl) cargoEl.innerHTML = parts.join('');
    });
  }
  // Mettascope owns scrubber UI; setStep tracks the step internally so
  // log highlighting + click-to-jump still work, but no on-page scrubber.
  var scrub = { value: 0 };
  var stepLabel = { textContent: '' };
  var search = document.getElementById('search');
  var log = document.getElementById('log');
  var typeChips = document.getElementById('type-chips');
  var tabs = document.getElementById('tabs');

  // Default-hide the per-tick `inventory` event type from the log; it's
  // the data source for the inventory panel and only adds noise inline.
  var hiddenTypes = {"inventory": true};
  var hiddenAgents = {};
  var currentTab = 'all';

  var currentStep = -1;
  var suppressMettascopePush = false;

  function setStep(step, agent) {
    step = Math.max(0, Math.min(maxStep, Math.floor(step)));
    // Always refresh the inventory panel — clicking a different line at
    // the same step should still highlight that row's agent.
    updateInventoryPanel(step);
    if (typeof agent === 'number' && !isNaN(agent)) {
      document.querySelectorAll('#inventory-panel .inv-row').forEach(
        function (r) { r.classList.remove('active'); });
      var row = document.querySelector(
        '#inventory-panel .inv-row[data-agent="' + agent + '"]');
      if (row) row.classList.add('active');
    }
    var sameStep = step === currentStep;
    if (sameStep && agent === undefined) {
      scrub.value = step;
      return;
    }
    currentStep = step;
    scrub.value = step;
    stepLabel.textContent = 'step ' + step + ' / ' + maxStep;
    // Forward to the embedded mettascope unless we were *called* because
    // mettascope told us to move (suppressMettascopePush guards that).
    // Optional `agent` selects + centers on that agent in mettascope.
    if (!suppressMettascopePush) {
      var iframe = document.getElementById('mettascope');
      if (iframe && iframe.contentWindow) {
        var msg = { type: 'mettascopeSetStep', step: step };
        if (typeof agent === 'number' && !isNaN(agent)) msg.agent = agent;
        iframe.contentWindow.postMessage(msg, '*');
      }
    }
    // Highlight current-step log lines.
    log.querySelectorAll('.line').forEach(function (el) {
      if (parseInt(el.dataset.step, 10) === step) el.classList.add('current');
      else el.classList.remove('current');
    });
    // Highlight the range marker if step falls inside it.
    log.querySelectorAll('.step-range').forEach(function (el) {
      var a = parseInt(el.dataset.start, 10);
      var b = parseInt(el.dataset.end, 10);
      if (step >= a && step <= b) el.classList.add('current');
      else el.classList.remove('current');
    });
    // Scroll first current line into view (or the current range marker
    // if we're inside an empty gap).
    var firstCurrent = log.querySelector('.line.current')
      || log.querySelector('.step-range.current');
    if (firstCurrent) firstCurrent.scrollIntoView({block: 'nearest'});
    updateInventoryPanel(step);
  }

  function applyFilters() {
    var q = (search.value || '').toLowerCase();
    // Reset any prior merge state before recomputing.
    log.querySelectorAll('.step-marker').forEach(function (el) {
      el.classList.remove('merged-hidden');
      el.classList.remove('hidden');
      if (el.dataset.original) el.textContent = el.dataset.original;
    });
    log.querySelectorAll('hr.step-sep').forEach(function (el) {
      el.classList.remove('hr-hidden');
    });
    log.querySelectorAll('.step-range-badge').forEach(function (el) {
      el.parentNode && el.parentNode.removeChild(el);
    });
    log.querySelectorAll('.line').forEach(function (el) {
      el.classList.remove('merged-hidden');
      el.classList.remove('in-merged-run');
      var type = el.dataset.type;
      var agent = el.dataset.agent;
      var stream = el.dataset.stream;
      var text = el.textContent.toLowerCase();
      var hide = false;
      if (hiddenTypes[type]) hide = true;
      if (agent !== '' && hiddenAgents[agent]) hide = true;
      if (currentTab === 'py' && stream !== 'py') hide = true;
      if (currentTab === 'llm' && stream !== 'llm') hide = true;
      if (currentTab === 'team' && agent !== '') hide = true;
      if (q && text.indexOf(q) === -1) hide = true;
      el.classList.toggle('hidden', hide);
    });
    // Hide step markers whose lines are all hidden (no visible content).
    log.querySelectorAll('.step-marker').forEach(function (marker) {
      var lines = _linesAfterMarker(marker);
      var visible = lines.filter(function (l) { return !l.classList.contains('hidden'); });
      if (visible.length === 0) marker.classList.add('hidden');
    });
    recomputeMerges();
  }

  // Return the sequence of .line elements that follow this step-marker
  // until the next step-marker / step-range.
  function _linesAfterMarker(marker) {
    var out = [];
    var el = marker.nextElementSibling;
    while (el) {
      if (el.classList.contains('step-marker') ||
          el.classList.contains('step-range') ||
          el.tagName === 'HR') break;
      if (el.classList.contains('line')) out.push(el);
      el = el.nextElementSibling;
    }
    return out;
  }

  function _lineKey(ln) {
    return (ln.dataset.agent || '') + '|' + ln.dataset.stream + '|' +
           ln.dataset.type + '|' + (ln.dataset.payload || '');
  }

  // Walk the currently-visible step-markers and merge runs of adjacent
  // markers whose visible-line *sets* match (same count, same keys).
  // Step keys formed from sorted line keys so multi-event steps merge
  // when the whole set repeats. Idempotent — applyFilters resets first.
  function _stepLineKeys(marker) {
    return _linesAfterMarker(marker)
      .filter(function (l) { return !l.classList.contains('hidden'); })
      .map(_lineKey)
      .sort()
      .join(';;');
  }
  function recomputeMerges() {
    var allMarkers = Array.prototype.slice.call(
      log.querySelectorAll('.step-marker'));
    var i = 0;
    while (i < allMarkers.length) {
      var marker = allMarkers[i];
      if (marker.classList.contains('hidden')) { i++; continue; }
      var visible = _linesAfterMarker(marker).filter(function (l) {
        return !l.classList.contains('hidden');
      });
      if (visible.length === 0) { i++; continue; }
      var key = _stepLineKeys(marker);
      var step = parseInt(marker.dataset.step, 10);
      var runEnd = step;
      var runMarkers = [];
      var runLines = [];
      var j = i + 1;
      while (j < allMarkers.length) {
        var m2 = allMarkers[j];
        if (m2.classList.contains('hidden')) { j++; continue; }
        var step2 = parseInt(m2.dataset.step, 10);
        if (step2 !== runEnd + 1) break;
        if (_stepLineKeys(m2) !== key) break;
        runEnd = step2;
        runMarkers.push(m2);
        _linesAfterMarker(m2).forEach(function (l) {
          if (!l.classList.contains('hidden')) runLines.push(l);
        });
        j++;
      }
      if (runMarkers.length > 0) {
        // Hide the start step-marker; show the range as a left-margin
        // badge on the first visible line, and indent all visible lines
        // of the run so the range column lines up horizontally.
        marker.classList.add('merged-hidden');
        var firstLine = visible[0];
        visible.forEach(function (l) { l.classList.add('in-merged-run'); });
        var badge = firstLine.querySelector('.step-range-badge');
        if (!badge) {
          badge = document.createElement('span');
          badge.className = 'step-range-badge';
          firstLine.insertBefore(badge, firstLine.firstChild);
        }
        badge.textContent = '[' + step + '..' + runEnd + ']';
        runMarkers.forEach(function (m) { m.classList.add('merged-hidden'); });
        runLines.forEach(function (l) { l.classList.add('merged-hidden'); });
      } else {
        marker.removeAttribute('data-step-end');
      }
      i = j;
    }
    // Keep exactly ONE hr between two visible blocks. Walk the log in
    // DOM order, tracking whether we've seen visible content since the
    // last kept hr. Skip hidden/merged-hidden children. A run of hrs
    // between two visible blocks collapses to the first; leading/
    // trailing hrs (no visible content on one side yet) hide.
    var children = Array.prototype.slice.call(log.children);
    var lastHadContent = false;  // visible non-hr content since last hr kept
    var pendingHr = null;        // hr waiting to be kept once content follows
    children.forEach(function (el) {
      if (el.classList.contains('hidden') ||
          el.classList.contains('merged-hidden')) {
        return;  // treat as if absent
      }
      if (el.tagName === 'HR') {
        if (lastHadContent) {
          // Keep the most recent hr across a run; collapse any prior
          // pendingHr (not yet flanked by content on both sides).
          if (pendingHr) pendingHr.classList.add('hr-hidden');
          pendingHr = el;
          lastHadContent = false;
        } else {
          el.classList.add('hr-hidden');
        }
      } else {
        // Visible content: the pending hr is now confirmed-visible.
        pendingHr = null;
        lastHadContent = true;
      }
    });
    // Trailing pending hr has no content after it — hide it.
    if (pendingHr) pendingHr.classList.add('hr-hidden');
  }

  // Clicking a log line, step marker, or empty-range jumps the scrubber.
  // For a .line click, also pass the agent so mettascope centers on it.
  log.addEventListener('click', function (e) {
    var target = e.target.closest('.line, .step-marker, .step-range');
    if (!target || !log.contains(target)) return;
    var step;
    if (target.classList.contains('step-range')) {
      step = parseInt(target.dataset.start, 10);
    } else {
      step = parseInt(target.dataset.step, 10);
    }
    if (isNaN(step)) return;
    scrub.value = step;
    var agentAttr = target.dataset.agent;
    if (agentAttr !== undefined && agentAttr !== '') {
      setStep(step, parseInt(agentAttr, 10));
    } else {
      setStep(step);
    }
  });

  typeChips.addEventListener('click', function (e) {
    var chip = e.target.closest('.chip');
    if (!chip) return;
    var t = chip.dataset.type;
    hiddenTypes[t] = !hiddenTypes[t];
    chip.classList.toggle('off', !!hiddenTypes[t]);
    applyFilters();
  });

  document.querySelectorAll('.agent-toggle').forEach(function (cb) {
    cb.addEventListener('change', function () {
      hiddenAgents[cb.dataset.agent] = !cb.checked;
      _syncAgentEyes();
      applyFilters();
    });
  });

  function _syncAgentEyes() {
    document.querySelectorAll('.agent-eye').forEach(function (btn) {
      var a = btn.dataset.agent;
      btn.classList.toggle('hidden-eye', !!hiddenAgents[a]);
    });
    document.querySelectorAll('.agent-toggle').forEach(function (cb) {
      cb.checked = !hiddenAgents[cb.dataset.agent];
    });
  }
  function _setAgentHidden(a, hidden) {
    hiddenAgents[a] = hidden;
  }
  document.querySelectorAll('.agent-eye').forEach(function (btn) {
    var a = btn.dataset.agent;
    btn.addEventListener('click', function (ev) {
      if (btn._dblTimer) { clearTimeout(btn._dblTimer); btn._dblTimer = null; }
      // Defer single-click a hair so a double-click can cancel it.
      btn._dblTimer = setTimeout(function () {
        btn._dblTimer = null;
        _setAgentHidden(a, !hiddenAgents[a]);
        _syncAgentEyes();
        applyFilters();
      }, 180);
    });
    btn.addEventListener('dblclick', function (ev) {
      if (btn._dblTimer) { clearTimeout(btn._dblTimer); btn._dblTimer = null; }
      // Solo toggle: if only this agent is visible, show all; else solo it.
      var allAgents = Array.prototype.slice.call(
        document.querySelectorAll('.agent-eye')
      ).map(function (b) { return b.dataset.agent; });
      var isOnlyVisible = allAgents.every(function (x) {
        return x === a ? !hiddenAgents[x] : !!hiddenAgents[x];
      });
      if (isOnlyVisible) {
        allAgents.forEach(function (x) { _setAgentHidden(x, false); });
      } else {
        allAgents.forEach(function (x) { _setAgentHidden(x, x !== a); });
      }
      _syncAgentEyes();
      applyFilters();
    });
  });

  tabs.addEventListener('click', function (e) {
    var b = e.target.closest('.tab');
    if (!b) return;
    currentTab = b.dataset.tab;
    tabs.querySelectorAll('.tab').forEach(function (x) {
      x.classList.toggle('active', x === b);
    });
    applyFilters();
  });

  search.addEventListener('input', applyFilters);

  // Collapsible filter panel.
  (function () {
    var btn = document.getElementById('filters-toggle');
    var panel = document.getElementById('log-filters');
    if (!btn || !panel) return;
    var stored = window.localStorage && localStorage.getItem('cgp-filters-collapsed');
    if (stored === '0') {
      panel.classList.remove('collapsed');
      btn.classList.remove('collapsed');
      btn.setAttribute('aria-expanded', 'true');
    }
    btn.addEventListener('click', function () {
      var collapsed = panel.classList.toggle('collapsed');
      btn.classList.toggle('collapsed', collapsed);
      btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
      try {
        if (window.localStorage) {
          localStorage.setItem('cgp-filters-collapsed', collapsed ? '1' : '0');
        }
      } catch (e) { /* localStorage may be disabled */ }
    });
  })();

  document.querySelectorAll('.jump-fail').forEach(function (b) {
    b.addEventListener('click', function () { setStep(+b.dataset.step); });
  });

  // Clicking a collapsed empty-range marker jumps to its start step.
  log.addEventListener('click', function (e) {
    var r = e.target.closest('.step-range');
    if (!r) return;
    setStep(+r.dataset.start);
  });

  // Delegated copy handler for any element with data-copy.
  document.addEventListener('click', function (e) {
    var el = e.target.closest('[data-copy]');
    if (!el) return;
    var text = el.getAttribute('data-copy') || '';
    if (navigator.clipboard) navigator.clipboard.writeText(text);
    var prev = el.textContent;
    el.textContent = 'copied';
    setTimeout(function () { el.textContent = prev; }, 2000);
  });

  // Listen for step updates from mettascope so our scrubber follows its
  // playback. We only trust messages whose source is our own iframe, and
  // we set suppressMettascopePush so setStep doesn't echo the value back.
  window.addEventListener('message', function (event) {
    var iframe = document.getElementById('mettascope');
    if (!iframe || event.source !== iframe.contentWindow) return;
    if (!event.data || event.data.type !== 'mettascopeStep') return;
    var step = event.data.step | 0;
    if (step === currentStep) return;
    suppressMettascopePush = true;
    setStep(step);
    suppressMettascopePush = false;
  });

  (function setupReplay() {
    var iframe = document.getElementById('mettascope');
    if (!iframe) return;
    var proto = window.location.protocol;
    if (proto === 'http:' || proto === 'https:') {
      var replayUrl = new URL('./replay.json.z', window.location.href).href;
      // Probe the locally-served mettascope dist; fall back to the
      // github-pages URL if the server didn't mount it (mixed content
      // may block it in browsers in that case).
      var localBase = new URL('./mettascope/mettascope.html', window.location.href).href;
      var remoteBase = 'https://metta-ai.github.io/metta/mettascope/mettascope.html';
      var showError = function () {
        iframe.outerHTML = '<div class="replay-fallback">Mettascope not available. Set <code>CVC_METTASCOPE_DIST</code> to a local mettascope <code>dist</code> directory, or install mettagrid with <code>dist</code> included.</div>';
      };
      var loadRemote = function () {
        fetch(remoteBase, {method: 'HEAD', mode: 'no-cors'}).then(function (r2) {
          if (r2.type === 'opaque' || r2.ok) {
            iframe.src = remoteBase + '?replay=' + encodeURIComponent(replayUrl);
          } else {
            showError();
          }
        }).catch(showError);
      };
      fetch('./mettascope/mettascope.html', {method: 'HEAD'}).then(function (r) {
        if (r.ok) {
          iframe.src = localBase + '?replay=' + encodeURIComponent(replayUrl);
        } else {
          loadRemote();
        }
      }).catch(loadRemote);
    } else {
      iframe.outerHTML = '<div class="replay-fallback">Open via <code>cgp view</code> for embedded replay (needs HTTP server).</div>';
    }
  })();

  // Drag-to-resize between replay and log columns. Stores the ratio in
  // localStorage so it survives reloads.
  (function () {
    var grid = document.getElementById('main-grid');
    var handle = document.getElementById('col-resize');
    if (!grid || !handle) return;
    var stored = window.localStorage && localStorage.getItem('cgp-cols');
    if (stored) grid.style.setProperty('--main-cols', stored);
    var dragging = false;
    var startX = 0;
    var startLeftPx = 0;
    function _setCols(leftPx) {
      var totalPx = grid.getBoundingClientRect().width;
      var rightPx = Math.max(80, totalPx - leftPx - handle.offsetWidth);
      var leftClamped = Math.max(80, totalPx - rightPx - handle.offsetWidth);
      var cols = leftClamped + 'px ' + handle.offsetWidth + 'px ' + rightPx + 'px';
      grid.style.setProperty('--main-cols', cols);
      try { if (window.localStorage) localStorage.setItem('cgp-cols', cols); }
      catch (e) {}
    }
    handle.addEventListener('pointerdown', function (e) {
      dragging = true;
      handle.classList.add('dragging');
      handle.setPointerCapture(e.pointerId);
      startX = e.clientX;
      startLeftPx = grid.firstElementChild.getBoundingClientRect().width;
    });
    handle.addEventListener('pointermove', function (e) {
      if (!dragging) return;
      _setCols(startLeftPx + (e.clientX - startX));
    });
    handle.addEventListener('pointerup', function (e) {
      dragging = false;
      handle.classList.remove('dragging');
      try { handle.releasePointerCapture(e.pointerId); } catch (err) {}
    });
  })();

  applyFilters();
  setStep(0);
})();
</script>
</body>
</html>
